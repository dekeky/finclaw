{
  "channels": {
    "my-feishu": {
      "enabled": true,
      "type": "feishu",
      "allow_from": [],
      "group_trigger": {
        "mention_only": true,
        "prefixes": ["/"]
      },
      "settings": {
        "app_id": "cli_xxxxxxxxxxxxxxx",
        "app_secret": "your-app-secret-here",
        "encrypt_key": "your-encrypt-key-here",
        "verification_token": "your-verification-token-here",
        "random_reaction_emoji": ["Pin", "Thumbsup"],
        "is_lark": false
      }
    },
    "my-weixin": {
      "enabled": true,
      "type": "weixin",
      "allow_from": [],
      "settings": {
        "token": "your-bot-token-here",
        "account_id": "your-account-id",
        "base_url": "https://ilinkai.weixin.qq.com/",
        "cdn_base_url": "https://novac2c.cdn.weixin.qq.com/c2c",
        "proxy": ""
      }
    },
    "my-telegram": {
      "enabled": false,
      "type": "telegram",
      "allow_from": [],
      "settings": {
        "token": "your-telegram-bot-token"
      }
    },
    "my-discord": {
      "enabled": false,
      "type": "discord",
      "allow_from": [],
      "settings": {
        "token": "your-discord-bot-token"
      }
    },
    "my-slack": {
      "enabled": false,
      "type": "slack",
      "allow_from": [],
      "settings": {
        "bot_token": "your-slack-bot-token",
        "app_token": "your-slack-app-token"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "claude-3-5-sonnet-20241022",
      "max_tokens": 4096
    }
  }
}
